# vibe-manager environment — copy to .env (repo root) or ~/.vibe-manager/.env
# Every variable is read by the `vibe` CLI at startup; `vibe doctor` verifies
# the lot before any LLM spend.

# REQUIRED — worker + agent auth (ADR-0002: API key only; never written to
# ~/.claude/.credentials.json; injected into worker subprocesses via an
# explicit env allowlist). Use a key with a per-key spend cap set in the
# Claude Console.
ANTHROPIC_API_KEY=

# REQUIRED — Supabase Postgres, SESSION MODE (direct port 5432, NOT the
# Supavisor transaction pooler on 6543 — pooling breaks session state and
# LISTEN/NOTIFY; vibe doctor rejects 6543). From the Supabase dashboard:
# Connect → Session mode connection string.
DATABASE_URL=

# OPTIONAL — Slack incoming-webhook URL for escalations (vision-affecting
# decisions). When unset, escalations are recorded in vibe_manager.events and
# printed, but CANNOT reach you while you're away — vibe run warns loudly.
SLACK_WEBHOOK_URL=

# OPTIONAL — absolute path to the claude binary if it is not on the daemon's
# PATH (launchd PATH differs from your shell PATH).
#VIBE_CLAUDE_BIN=/usr/local/bin/claude

# Supabase project keys (not used by the orchestrator runtime; kept for
# Studio/tooling convenience).
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# NOTE: no OpenAI key is needed yet — the memory table ships in migration
# 0001 but the embedder (text-embedding-3-large) arrives with M4b.
